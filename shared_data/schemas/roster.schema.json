{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "roster.schema.json",
  "title": "PlayerRoster",
  "type": "object",
  "required": ["player_id", "army_id", "detachment_id", "points_limit", "units"],
  "properties": {
    "player_id": { "type": "string" },
    "army_id": { "type": "string" },
    "detachment_id": { "type": "string" },
    "points_limit": { "type": "integer", "minimum": 1 },
    "units": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["instance_id", "unit_id", "model_count", "role_counts", "selected_wargear", "points_total"],
        "properties": {
          "instance_id": { "type": "string" },
          "unit_id": { "type": "string" },
          "model_count": { "type": "integer", "minimum": 1, "maximum": 20 },
          "role_counts": {
            "type": "object",
            "additionalProperties": { "type": "integer", "minimum": 0, "maximum": 20 }
          },
          "selected_wargear": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["option_id", "choice_item_id", "applied_to_role_id", "count"],
              "properties": {
                "option_id": { "type": "string" },
                "choice_item_id": { "type": "string" },
                "applied_to_role_id": { "type": "string" },
                "count": { "type": "integer", "minimum": 1, "maximum": 20 }
              },
              "additionalProperties": false
            }
          },
          "attached_leader_instance_ids": {
            "type": "array",
            "items": { "type": "string" },
            "uniqueItems": true
          },
          "points_total": { "type": "integer", "minimum": 0 }
        },
        "additionalProperties": false
      }
    },
    "cp_start": { "type": "integer", "minimum": 0, "default": 0 },
    "points_total": { "type": "integer", "minimum": 0 }
  },
  "additionalProperties": false
}
