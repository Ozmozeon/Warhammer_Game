{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "stratagem.schema.json",
  "title": "StratagemDefinition",
  "type": "object",
  "required": ["id", "name", "detachment_id", "cp_cost", "timing", "targeting", "effects", "usage_limit"],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9_]+$" },
    "name": { "type": "string" },
    "detachment_id": { "type": "string" },
    "cp_cost": { "type": "integer", "minimum": 0 },
    "timing": {
      "type": "object",
      "required": ["phase_windows"],
      "properties": {
        "phase_windows": { "type": "array", "items": { "type": "string" } },
        "trigger": { "type": "string" }
      },
      "additionalProperties": false
    },
    "targeting": {
      "type": "object",
      "required": ["target_type"],
      "properties": {
        "target_type": { "type": "string", "enum": ["self", "single_friendly_unit", "single_enemy_unit", "multiple_units", "area"] },
        "max_targets": { "type": "integer", "minimum": 1 },
        "required_keywords": { "type": "array", "items": { "type": "string" } },
        "exclude_keywords": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "effects": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["effect_type"],
        "properties": {
          "effect_type": { "type": "string" },
          "duration": { "type": "string", "enum": ["instant", "end_of_phase", "end_of_turn", "persistent"] },
          "params": { "type": "object", "additionalProperties": true }
        },
        "additionalProperties": false
      }
    },
    "usage_limit": {
      "type": "object",
      "required": ["scope", "max_uses"],
      "properties": {
        "scope": { "type": "string", "enum": ["battle", "turn", "phase"] },
        "max_uses": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
